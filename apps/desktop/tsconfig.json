{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "spec/**/*.ts",
    "spec/**/*.tsx",
    "scripts/**/*.ts",
    "vite.config.ts",
    "vitest.setup.ts"
  ]
}
